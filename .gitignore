#############################################
# Root .gitignore (sanitized & deduplicated)
#############################################

# Transient / operational JSON outputs (az cli / REST dumps / deployment outputs)
webapp*_settings.json
webapp*_rfp.json
webapps_list.json
zone_list.json
*_list.json
subs_*.json
subs.json
shared_*.json
ua-assign-*.json
*assign-ops*.json
policy-child-template.json

# Generic temp / logs
*.log
*.tmp
~$*
*.bak

# PowerShell transient output
*.ps1.xml

# Node / JS
node_modules/
**/node_modules/
package-lock.json
**/package-lock.json
**/packages-lock.json
**/dist/
**/coverage/

# Archives / bundles
*.zip
*.rar
*.7z

# IDE / Editor
.vscode/
.vs/
*.suo
*.user
*.userprefs
*.opendb
*.VC.db

# Unity (trimmed standard set)
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Mm]emoryCaptures/
ExportedObj/
.consulo/
*.pidb
*.pdb
*.mdb
*.apk
*.unitypackage
crashlytics-build.properties
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*
**/Library/PackageCache/
**/Library/
**/Temp/
**/Logs/
**/UserSettings/

# Keep meta files when assets tracked
!/[Aa]ssets/**/*.meta

# Unreal (if present)
MyProject/Binaries/
MyProject/DerivedDataCache/
MyProject/Intermediate/
MyProject/Saved/
MyProject/.vs/
AzureVrProject/Binaries/
AzureVrProject/DerivedDataCache/
AzureVrProject/Intermediate/
AzureVrProject/Saved/
AzureVrProject/.vs/

# Python
**/__pycache__/
*.pyc
*.pyo
*.pyd
.python-version
.venv/
venv/
ENV/
env/

# NuGet / temp
temp-nuget/

# OS cruft
.DS_Store
Thumbs.db

# Secrets patterns (never commit real credentials)
SEOOptimizer/client_secret_*.json

# Legacy / large project dirs (ignore if regenerated)
AzureVRPRoject/

# Local deployment parameter wrappers (environment-specific)
*.bicepparam
bicep/paramfiles/*.bicepparam

# End of file
